# PostgreSQL (Neon)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# OpenAI — server-side only. Never prefix with NEXT_PUBLIC_
OPENAI_API_KEY=""
OPENAI_DAILY_TOKEN_BUDGET="500000"

# Optional free-first market providers
COINGECKO_API_KEY=""
TWELVE_DATA_API_KEY=""
ALPHA_VANTAGE_API_KEY=""
MARKET_BASE_CURRENCY="USD"

# Unofficial development overlay; disable for production truth
ENABLE_YAHOO_PROTOTYPE="true"

# Cron job protection
CRON_SECRET="replace-me-with-a-long-random-secret"

# Clerk auth
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
